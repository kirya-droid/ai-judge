# Пример файла .env для Docker
# Скопируйте этот файл в .env и заполните своими значениями

# API ключ для AI (DeepSeek или другой)
DEEPSEEK_API_KEY=your_api_key_here

# Уровень логирования
LOG_LEVEL=INFO

# CORS настройки - список разрешенных origin через запятую
ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Rate Limiting - максимум запросов в минуту на один IP
RATE_LIMIT_PER_MINUTE=30

# Порт сервера
PORT=8001
